{
  "name": "quasar-scaffold-store",
  "version": "1.0.3",
  "description": "Sistema de gestión de agendas para empresas, desarrollado con Quasar Framework y Laravel, que permite a los usuarios crear, gestionar y compartir sus agendas de manera eficiente.",
  "productName": "Agendas - GrupoAdos.com",
  "author": "Grupo Empresarial Ados <contactogrupoados@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
