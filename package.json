    "@supabase/supabase-js": "^2.53.0",
    "axios": "^1.13.5",
    "chart.js": "^4.5.1",
    "jsbarcode": "^3.12.3",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "quasar": "^2.18.6",
    "vue": "^3.5.18",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@intlify/unplugin-vue-i18n": "^2.0.0",
    "@quasar/app-vite": "^2.4.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "globals": "^15.12.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-plugin-checker": "^0.8.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
