#API_URL=http://saas.local:8000 # Laravel
API_URL=https://api.bitwia.com
API_REPO_URL=storage/repo/

# Dominios de la aplicación
# Subdominio específico (agendas o parking)
VITE_SUBDOMAIN=agendas
# Dominio base en producción (ejemplo: grupoados.com)
VITE_BASE_DOMAIN=grupoados.com
# Dominio local para desarrollo (ejemplo: agendas.local o parking.local)
VITE_LOCAL_DOMAIN=agendas.local

# Google reCAPTCHA v3
# Site key de reCAPTCHA v3 - reemplaza con tu site key real
# Esta es la key que se está usando actualmente en el código
VITE_RECAPTCHA_SITE_KEY=key---key---site----
